{
  "name": "swarm-secrets-manager",
  "exports": "./main.tsx",
  "version": "1.0.2",
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "start": "deno run --allow-net --allow-env --allow-read=/app --allow-run=curl --no-prompt main.tsx",
    "dev": "MOCK_SECRETS_API=1 CONFIG_JSON_PATH=./config.local.json deno run --allow-net --allow-env --allow-read=. --allow-run=curl --no-prompt --watch main.tsx",
    "openapi-ts": "deno run -A npm:@hey-api/openapi-ts"
  },
  "imports": {
    "@dldc/hono-ui": "jsr:@dldc/hono-ui@^1.4.0",
    "@hey-api/openapi-ts": "npm:@hey-api/openapi-ts@^0.96.1",
    "@hono/hono": "jsr:@hono/hono@^4.12.15",
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.1",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.3.1",
    "hono": "jsr:@hono/hono@^4.12.14"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
